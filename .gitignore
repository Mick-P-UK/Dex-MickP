# ============================================
# Dex-MickP - SINGLE PRIVATE REPO
# Decision 2026-07-11: this repo holds EVERYTHING personal and is never published.
# If a system/structure is ever shared, a scrubbed DEMO repo is derived separately.
# So we ignore only machine junk and SECRETS. All personal content is tracked.
# ============================================

# OS / editor junk
.DS_Store
Thumbs.db
.vscode/
*.swp
*.swo

# Node / Python build artefacts
node_modules/
__pycache__/

# Obsidian per-machine workspace (not portable, no backup value)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# ============================================
# SECRETS - NEVER COMMIT (kept out even though repo is private)
# ============================================
.env
.env.*
.mcp.json
System/.credentials/
System/.credentials/*.json
System/.credentials/*.pickle
System/.credentials/*.token
*.token
*.pickle

# Local pre-clean safety copies from the 2026-07-11 single-repo migration (not backed up)
*-bak-2026-07-11
*.bak-2026-07-11

# Volatile runtime logs - keep curated _changelog/ only
*.log
!_changelog/*.log
.playwright-mcp/

# Nested project repo (own git history) - backed up in its own repo, not here
04-Projects/2026.04.04-ShareScope-Automation/
