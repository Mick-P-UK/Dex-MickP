# ax-trees-automation - Environment Variables Template
# Copy this file to .env and fill in real values.
# The real .env lives OUTSIDE the GitHub-committed vault.
# Never commit .env. Never hardcode credentials in scripts.

# ShareScope credentials
SHARESCOPE_USERNAME=
SHARESCOPE_PASSWORD=
SHARESCOPE_URL=

# Stockopedia credentials (when needed)
STOCKOPEDIA_USERNAME=
STOCKOPEDIA_PASSWORD=
STOCKOPEDIA_URL=

# Playwright settings
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_SLOWMO=0
